# =============================================================================
#  opensea-auto-mint-bot — Environment Configuration
#  by Genoshide | github.com/genoshide/opensea-auto-mint-bot
#
#  Copy this file to .env and fill in your values.
#  Lines starting with # are comments and are ignored.
# =============================================================================


# -----------------------------------------------------------------------------
# NETWORK
# Options: ETH | BASE | OP | ARB | POLY | BSC | AVAX | BERA | MONAD | ABSTRACT
# -----------------------------------------------------------------------------
NETWORK="BASE"


# -----------------------------------------------------------------------------
# TARGET
# NFT_CONTRACT_ADDRESS : the contract to mint from (find on opensea.io/drops)
# MINT_QUANTITY        : number of NFTs to mint per wallet
# -----------------------------------------------------------------------------
NFT_CONTRACT_ADDRESS="0x..."
MINT_QUANTITY="1"


# -----------------------------------------------------------------------------
# MINTING MODE
# PROXY  — mint via the OpenSea MultiMint contract (batched, uses MULTIMINT_ADDRESS)
# DIRECT — call the NFT contract directly using MINT_FUNC_NAME
# -----------------------------------------------------------------------------
MINT_MODE="DIRECT"
MINT_FUNC_NAME="mint"        # mint | publicMint | purchase | claim

FORCE_START=false            # true = skip timer and mint immediately


# -----------------------------------------------------------------------------
# SYSTEM CONTRACTS  (change only if OpenSea deploys a new version)
# -----------------------------------------------------------------------------
SEA_DROP_ADDRESS="0x00005EA00Ac477B1030CE78506496e8C2dE24bf5"
MULTIMINT_ADDRESS="0x0000419B4B6132e05DfBd89F65B165DFD6fA126F"


# -----------------------------------------------------------------------------
# PERFORMANCE
# MAX_WORKERS     : concurrent wallets running in parallel
# GAS_PRICE_GWEI  : leave blank for auto-detection from RPC
# MAX_GAS_LIMIT   : pause execution if live gas (Gwei) exceeds this value
# RETRY_DELAY_*   : random delay range (seconds) between retry attempts
# -----------------------------------------------------------------------------
MAX_WORKERS="5"
GAS_PRICE_GWEI=""            # blank = auto
MAX_GAS_LIMIT="50"
RETRY_DELAY_MIN="1.5"
RETRY_DELAY_MAX="3.0"


# -----------------------------------------------------------------------------
# GOD MODE — Pre-Signed Transactions
# Signs raw transactions before the mint opens and broadcasts at T-0.
# PRE_SIGN_GAS_MULTIPLIER : gas price buffer (2.0 = 2x current price)
# PRE_SIGN_GAS_LIMIT      : hardcoded gas limit (estimates fail before mint opens)
#                           standard NFT mint range: 150000–300000
# -----------------------------------------------------------------------------
PRE_SIGN_ENABLED=false
PRE_SIGN_GAS_MULTIPLIER="2.0"
PRE_SIGN_GAS_LIMIT="300000"


# -----------------------------------------------------------------------------
# AUTO-FUNDER
# Tops up worker wallets from a master wallet if balance < MIN_WORKER_BALANCE.
# -----------------------------------------------------------------------------
AUTO_FUND_ENABLED=false
MASTER_PRIVATE_KEY="0x..."
MIN_WORKER_BALANCE="0.005"   # ETH — fund workers below this threshold
FUNDING_AMOUNT="0.01"        # ETH — amount to send per top-up


# -----------------------------------------------------------------------------
# AUTO-TRANSFER  (NFT Consolidation)
# Sends minted NFTs to RECIPIENT_ADDRESS immediately after a successful mint.
# -----------------------------------------------------------------------------
AUTO_TRANSFER_ENABLED=false
RECIPIENT_ADDRESS="0x..."


# -----------------------------------------------------------------------------
# DUST SWEEPER
# Sweeps leftover ETH from worker wallets back to RECIPIENT_ADDRESS after execution.
# -----------------------------------------------------------------------------
AUTO_SWEEP_ETH=false
MIN_ETH_TO_SWEEP="0.005"     # minimum balance to sweep (avoids sweeping less than gas cost)


# -----------------------------------------------------------------------------
# PROXIES
# Reads proxy list from proxies.txt (one per line: user:pass@ip:port)
# -----------------------------------------------------------------------------
USE_PROXIES=false


# -----------------------------------------------------------------------------
# DISCORD NOTIFICATIONS
# Sends alerts on successful mints and transfers via webhook.
# -----------------------------------------------------------------------------
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."


# -----------------------------------------------------------------------------
# ACCOUNTANT
# Logs every transaction, gas cost, and total spend to history.csv.
# -----------------------------------------------------------------------------
ACCOUNTANT_ENABLED=false


# -----------------------------------------------------------------------------
# CONTRACT VERIFIER  (Anti-Honeypot)
# Checks that the contract source is verified on the block explorer before minting.
# Get a free API key: etherscan.io | basescan.org | arbiscan.io (match your NETWORK)
# -----------------------------------------------------------------------------
VERIFY_CONTRACT_ENABLED=false
EXPLORER_API_KEY=""
